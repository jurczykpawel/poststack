# ============================================================
# ReplyStack — Environment Variables
# Copy to .env and fill in your values.
# Generate secrets with: openssl rand -hex 32
# ============================================================

# --- Database ---
# DATABASE_URL here uses localhost — that is for running the app directly on the
# host during development (with `docker compose up postgres`). The bundled prod
# deployment (docker-compose.prod.yml) ignores this value and derives DATABASE_URL
# from the POSTGRES_* vars below, pointing at the in-network `postgres` service.
DATABASE_URL="postgresql://replystack:replystack-dev@localhost:5432/replystack"
POSTGRES_USER=replystack
POSTGRES_PASSWORD=replystack-dev
POSTGRES_DB=replystack
# Connection-pool resilience (optional). DB_POOL_MAX caps connections per web/worker process
# (default 10) — size the total against postgres max_connections (see README → Production).
# The timeouts cancel a runaway statement / an idle-in-transaction session so it can't pin a
# pooled connection forever; set to 0 to disable. Defaults: 30000 ms / 60000 ms.
# DB_POOL_MAX=10
# DB_STATEMENT_TIMEOUT_MS=30000
# DB_IDLE_TX_TIMEOUT_MS=60000

# --- Auth ---
# Generate: openssl rand -hex 32
JWT_SECRET=change-me-generate-with-openssl-rand-hex-32
JWT_EXPIRY=7d

# --- Encryption ---
# AES-256-GCM key for OAuth token storage. Any passphrase >= 32 chars (sha256-derived).
# Generate: openssl rand -base64 32
ENCRYPTION_KEY=change-me-generate-with-openssl-rand-base64-32

# --- App ---
APP_URL=http://localhost:3000

# --- Media storage (optional: S3-compatible — Backblaze B2 / R2 / MinIO) ---
# With STORAGE_ENDPOINT unset, media uses an in-memory store (dev/tests). STORAGE_PUBLIC_BASE_URL
# must serve the bucket publicly so platforms can pull the asset (e.g. Meta `url=` publish).
# STORAGE_PUBLIC_BUCKET is the shared content-addressed bucket — same name as ReelStack so a reel it
# rendered can be linked here by reference (no re-upload).
# STORAGE_ENDPOINT=https://s3.eu-central-003.backblazeb2.com
# STORAGE_REGION=eu-central-003
# STORAGE_PUBLIC_BUCKET=tsa-media-public
# STORAGE_ACCESS_KEY_ID=change-me
# STORAGE_SECRET_ACCESS_KEY=change-me
# STORAGE_PUBLIC_BASE_URL=https://cdn.techskills.academy/file/tsa-media-public

# --- Integrations (optional) ---
# ReelStack reel.completed webhook → auto-register the rendered reel as media (no re-upload).
# OFF by default: BOTH are required to enable POST /integrations/reelstack/webhook. The secret must
# equal ReelStack's WEBHOOK_CALLBACK_SECRET (HMAC); the workspace id is the tenant reels register into.
# REELSTACK_WEBHOOK_SECRET=change-me
# REELSTACK_WEBHOOK_WORKSPACE_ID=00000000-0000-0000-0000-000000000000

# --- Reverse proxy trust ---
# How the client IP for rate limiting is derived. Forwarding headers are only
# trusted when this is set, because a directly-exposed app cannot tell a real
# header from a forged one.
#   unset/empty -> trust NO header; every request shares one bucket (coarse but
#                  un-bypassable). Only safe if you never expose the app directly.
#   "proxy"     -> trust X-Real-IP / the rightmost X-Forwarded-For hop. Use this
#                  with the bundled nginx (it sets X-Real-IP to the real client).
#   "cloudflare"-> trust CF-Connecting-IP. ONLY behind Cloudflare, and restrict
#                  the origin to Cloudflare IP ranges at the firewall.
# Leave unset for a directly-exposed app (safe default below). The bundled docker
# deployment sets TRUSTED_PROXY=proxy for you via compose, so you do not need to
# uncomment this unless you run your own reverse proxy.
# TRUSTED_PROXY=proxy

# --- Meta (Facebook & Instagram) ---
# Create an app at https://developers.facebook.com
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
# Must match exactly what you configure in Meta App Dashboard > Webhooks
# Use the displayed webhook URL from /channels page
META_WEBHOOK_VERIFY_TOKEN=change-me-random-string

# --- CAPTCHA (Altcha) ---
# Proof-of-work CAPTCHA on login/register. Without this key verification is
# SKIPPED — fine for local dev, but SET IT IN PRODUCTION or the bot/brute-force
# defence on those endpoints is off. Solved challenges are single-use (no replay).
# Generate: openssl rand -hex 32
# ALTCHA_HMAC_KEY=change-me-generate-with-openssl-rand-hex-32

# --- Cron ---
# Shared secret to protect cron endpoints
# Generate: openssl rand -hex 32
CRON_SECRET=change-me-generate-with-openssl-rand-hex-32

# --- Alerts ---
# Optional: outbound webhook POSTed when a channel needs re-authentication.
# Point it at your own n8n / Slack / ntfy / email service. Unset = no alerts.
# Must be an http(s) URL to a public or loopback host, or an internal hostname
# (e.g. a docker-compose service name). A private/link-local IP *literal*
# (10.x, 172.16-31.x, 192.168.x, 169.254.x, fc00::/7, fe80::/10) is rejected at
# startup to prevent server-side requests to internal addresses.
# CHANNEL_ALERT_WEBHOOK_URL=https://your-endpoint.example/replystack-alerts

# --- AI rephrase (optional) ---
# Used by the ai_rephrase rule response type. Unset OPENAI_API_KEY = feature off
# (rules fall back to the literal text). Works with any OpenAI-compatible endpoint.
# PRIVACY: when set, the reply text is sent to that LLM provider. If you process
# personal data (GDPR), point OPENAI_BASE_URL at an endpoint with a suitable DPA
# (or a self-hosted model) and disclose it in your privacy policy.
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# AI_REPHRASE_MODEL=gpt-4o-mini

# --- Production images (docker-compose.prod.yml only) ---
# Pre-built images are published to GHCR by CI. Defaults work out of the box.
# Forks: override IMAGE_REPO with your own registry path (worker image is
# IMAGE_REPO + "-worker"). If the GHCR packages are private, run
# `docker login ghcr.io` before `docker compose -f docker-compose.prod.yml up`.
# IMAGE_REPO=ghcr.io/jurczykpawel/poststack
# IMAGE_TAG=latest
# PORT=80
