# ============================================================
# ReplyStack — Environment Variables
# Copy to .env and fill in your values.
# Generate secrets with: openssl rand -hex 32
# ============================================================

# --- Database ---
DATABASE_URL="postgresql://replystack:replystack-dev@localhost:5432/replystack"
POSTGRES_USER=replystack
POSTGRES_PASSWORD=replystack-dev
POSTGRES_DB=replystack

# --- Redis ---
REDIS_URL="redis://:replystack-dev@localhost:6379"
REDIS_PASSWORD=replystack-dev

# --- Auth ---
# Generate: openssl rand -hex 32
JWT_SECRET=change-me-generate-with-openssl-rand-hex-32
JWT_EXPIRY=7d

# --- Encryption ---
# AES-256-GCM key for OAuth token storage. MUST be 32-byte hex.
# Generate: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=change-me-generate-with-openssl-rand-hex-32

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Meta (Facebook & Instagram) ---
# Create an app at https://developers.facebook.com
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
# Must match exactly what you configure in Meta App Dashboard > Webhooks
# Use the displayed webhook URL from /channels page
META_WEBHOOK_VERIFY_TOKEN=change-me-random-string

# --- Cron ---
# Shared secret to protect cron endpoints
# Generate: openssl rand -hex 32
CRON_SECRET=change-me-generate-with-openssl-rand-hex-32
