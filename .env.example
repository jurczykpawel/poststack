# ============================================================
# PostStack — Environment Variables
#
# Copy to `.env` and fill in the REQUIRED values. Everything else has a sane
# default and can stay unset. Generate secrets with:  openssl rand -hex 32
#
# Legend:  [REQUIRED] must be set or the app refuses to boot.
#          [optional] has a default (shown); safe to leave unset.
# The app validates this file at startup (src/lib/env.ts) — a missing required
# value or a malformed URL fails fast with a clear message, not at runtime.
# ============================================================


# ─── Database ───────────────────────────────────────────────
# [REQUIRED] PostgreSQL connection string.
# The localhost value is for running the app directly on the host in dev
# (with `docker compose up postgres`). The bundled prod deployment
# (docker-compose.prod.yml) ignores this and derives DATABASE_URL from the
# POSTGRES_* vars below, pointing at the in-network `postgres` service.
DATABASE_URL="postgresql://poststack:poststack-dev@localhost:5432/poststack"

# Used by docker-compose to create the bundled Postgres + build DATABASE_URL.
POSTGRES_USER=poststack
POSTGRES_PASSWORD=poststack-dev
POSTGRES_DB=poststack

# [optional] Connection-pool resilience. DB_POOL_MAX caps connections per
# web/worker process (default 10) — size the total against postgres
# max_connections. The timeouts cancel a runaway statement / an
# idle-in-transaction session so it can't pin a pooled connection forever;
# set 0 to disable. Defaults: 30000 ms / 60000 ms.
# DB_POOL_MAX=10
# DB_STATEMENT_TIMEOUT_MS=30000
# DB_IDLE_TX_TIMEOUT_MS=60000


# ─── Auth ───────────────────────────────────────────────────
# [REQUIRED] JWT signing secret for session cookies. Min 32 chars.
# Generate: openssl rand -hex 32
JWT_SECRET=change-me-generate-with-openssl-rand-hex-32

# [optional] Session lifetime (default "7d"). Accepts e.g. "12h", "30d".
JWT_EXPIRY=7d

# [optional] Open self-registration. Default "false": only the FIRST user (empty
# instance) may register to bootstrap the admin. Set "true" to allow anyone to
# sign up (each new account = a new workspace; multi-tenant beyond the first
# requires the `business` tier).
# REGISTRATION_ENABLED=false


# ─── Encryption ─────────────────────────────────────────────
# [REQUIRED] At-rest AES-256-GCM key for stored OAuth tokens & secrets. Any
# passphrase >= 32 chars (sha256-derived to a 32-byte key). Rotating it makes
# previously-stored tokens undecryptable (channels need reconnect) — keep it stable.
# Generate: openssl rand -base64 32
ENCRYPTION_KEY=change-me-generate-with-openssl-rand-base64-32


# ─── App ────────────────────────────────────────────────────
# [REQUIRED] Public URL of this instance. Drives OAuth redirect URIs, the
# displayed webhook URL, and the same-origin guard on dashboard POSTs — it MUST
# match the host users actually reach the app on.
APP_URL=http://localhost:3000

# [optional] Runtime mode: development | production | test (default development).
# In production the app warns on startup about lax security settings
# (unset ALTCHA_HMAC_KEY, unset TRUSTED_PROXY).
# NODE_ENV=production

# [optional] HTTP port the server listens on (default 3000). The bundled prod
# compose sets this for you.
# PORT=3000


# ─── Reverse proxy trust ────────────────────────────────────
# [optional] How the client IP for rate limiting is derived. Forwarding headers
# are only trusted when this is set (a directly-exposed app can't tell a real
# header from a forged one).
#   unset/empty  -> trust NO header; every request shares ONE rate-limit bucket
#                   (coarse but un-bypassable). Only safe if never exposed directly.
#   "proxy"      -> trust X-Real-IP / the rightmost X-Forwarded-For hop. Use with
#                   the bundled nginx (sets X-Real-IP to the real client).
#   "cloudflare" -> trust CF-Connecting-IP. ONLY behind Cloudflare, and restrict
#                   the origin to Cloudflare IP ranges at the firewall.
# The bundled docker deployment sets TRUSTED_PROXY=proxy for you via compose.
# TRUSTED_PROXY=proxy


# ─── Cron ───────────────────────────────────────────────────
# [REQUIRED] Shared secret protecting the cron HTTP endpoints. Min 32 chars.
# Generate: openssl rand -hex 32
CRON_SECRET=change-me-generate-with-openssl-rand-hex-32


# ─── CAPTCHA (ALTCHA) ───────────────────────────────────────
# [optional] Proof-of-work CAPTCHA HMAC key for login/register. Without it,
# verification is SKIPPED — fine for local dev, but SET IT IN PRODUCTION or the
# bot/brute-force defence on those endpoints is off (the app warns at boot).
# Solved challenges are single-use (no replay). Can also be set in-app at
# Settings → Security (a DB value overrides this env var).
# Generate: openssl rand -hex 32
# ALTCHA_HMAC_KEY=change-me-generate-with-openssl-rand-hex-32


# ─── Meta (Facebook & Instagram) ────────────────────────────
# [optional] Needed to connect FB/IG channels. The app starts without them, but
# OAuth + webhooks won't work until set. Create an app at
# https://developers.facebook.com. Can also be set in-app at Settings.
# META_WEBHOOK_VERIFY_TOKEN must match what you enter in Meta App Dashboard →
# Webhooks; use the webhook URL shown on the /channels page.
# META_APP_ID=your-meta-app-id
# META_APP_SECRET=your-meta-app-secret
# META_WEBHOOK_VERIFY_TOKEN=change-me-random-string


# ─── Google / YouTube / Gmail ──────────────────────────────
# [optional] OAuth client for connecting YouTube channels (comment automation) and
# Gmail mailboxes (inbox automation). One Google app can serve both — just enable
# the Gmail API in the project, add scopes:
# - openid, email
# - https://www.googleapis.com/auth/gmail.readonly
# - https://www.googleapis.com/auth/gmail.send
# Can also be set in-app at Settings.
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret


# ─── Media storage (S3-compatible: Backblaze B2 / R2 / MinIO) ─
# [optional] With STORAGE_ENDPOINT unset, media uses an in-memory store
# (dev/tests). STORAGE_PUBLIC_BASE_URL must serve the bucket publicly so
# platforms can pull the asset (e.g. Meta `url=` publish). STORAGE_PUBLIC_BUCKET
# is the shared content-addressed bucket — same name as ReelStack so a reel it
# rendered can be linked here by reference (no re-upload). STORAGE_REGION
# defaults to "auto".
# STORAGE_ENDPOINT=https://s3.eu-central-003.backblazeb2.com
# STORAGE_REGION=eu-central-003
# STORAGE_PUBLIC_BUCKET=tsa-media-public
# STORAGE_ACCESS_KEY_ID=change-me
# STORAGE_SECRET_ACCESS_KEY=change-me
# STORAGE_PUBLIC_BASE_URL=https://cdn.techskills.academy/file/tsa-media-public


# ─── AI rephrasing (OpenAI-compatible) ──────────────────────
# [optional] Powers the `ai_rephrase` rule response type (a PRO feature). Unset
# AI_API_KEY = feature off (rules fall back to the literal text). Works with ANY
# OpenAI-compatible chat-completions endpoint — set AI_BASE_URL + AI_MODEL:
#   OpenAI      AI_BASE_URL=https://api.openai.com/v1     AI_MODEL=gpt-4o-mini
#   OpenRouter  AI_BASE_URL=https://openrouter.ai/api/v1  AI_MODEL=anthropic/claude-3.5-haiku
#   Groq        AI_BASE_URL=https://api.groq.com/openai/v1 AI_MODEL=llama-3.3-70b-versatile
#   Ollama      AI_BASE_URL=http://localhost:11434/v1     AI_MODEL=llama3.1
# AI_REPHRASE_DAILY_LIMIT caps paid LLM calls per workspace over a rolling 24h
# window (default 1000); over the cap, rephrase fails soft to the base text —
# guards against an inbound flood running up the bill.
# PRIVACY: when set, reply text is sent to that provider. If you process personal
# data (GDPR), point AI_BASE_URL at an endpoint with a suitable DPA (or a
# self-hosted model like Ollama) and disclose it in your privacy policy.
# AI_API_KEY=sk-...
# AI_BASE_URL=https://api.openai.com/v1
# AI_MODEL=gpt-4o-mini
# AI_REPHRASE_DAILY_LIMIT=1000
# Legacy names still honored (deprecated): OPENAI_API_KEY, OPENAI_BASE_URL, AI_REPHRASE_MODEL


# ─── Alerts ─────────────────────────────────────────────────
# [optional] Outbound webhook POSTed when a channel needs re-authentication.
# Point it at your own n8n / Slack / ntfy / email service. Unset = no alerts.
# Must be an http(s) URL to a public or loopback host, or an internal hostname
# (e.g. a docker-compose service name). A private/link-local IP *literal*
# (10.x, 172.16-31.x, 192.168.x, 169.254.x, fc00::/7, fe80::/10) is rejected at
# startup to prevent server-side requests to internal addresses (SSRF).
# CHANNEL_ALERT_WEBHOOK_URL=https://your-endpoint.example/poststack-alerts


# ─── Integrations ───────────────────────────────────────────
# [optional] ReelStack `reel.completed` inbound webhook → auto-register the
# rendered reel as media (no re-upload). OFF by default: BOTH are required to
# enable POST /integrations/reelstack/webhook. The secret must equal ReelStack's
# WEBHOOK_CALLBACK_SECRET (HMAC); the workspace id is the tenant reels register into.
# REELSTACK_WEBHOOK_SECRET=change-me
# REELSTACK_WEBHOOK_WORKSPACE_ID=00000000-0000-0000-0000-000000000000


# ─── History compaction (database hygiene) ──────────────────
# [optional] Window (days) after which webhook_events + post_reactions are rolled
# into compact aggregates and the raw rows deleted (runs daily). All-time counts
# and the Engagement view stay correct — only raw payloads and reactor identity
# are dropped. 0 = disabled (those tables grow unbounded). If set, must be >= 30.
# Default 60.
# HISTORY_RETENTION_DAYS=60

# [optional] In-process cache for the dashboard stats tiles (webhook + engagement
# aggregates). Repeated dashboard loads reuse the last result for this many
# milliseconds instead of re-scanning the raw tables every request. 0 = disabled
# (always live). Default 30000 (30s). Stats tiles tolerate brief staleness; this just
# bounds DB work under rapid refreshes. Raise for very busy instances, set 0 if you
# need to-the-second numbers.
# STATS_CACHE_TTL_MS=30000


# ─── Marketing landing analytics (optional, runtime) ────────
# The public landing (served at `/`) loads analytics only when these are set — nothing is baked
# into the image. Leave unset (e.g. on a test/staging deploy) and the landing loads zero trackers
# and shows no cookie banner. The app injects these into the page at request time.
# LANDING_UMAMI_WEBSITE_ID=   # Umami website id → cookieless analytics
# LANDING_UMAMI_SRC=          # optional; default https://stats.techskills.academy/script.js
# LANDING_GTM_ID=             # GTM-XXXXXXX → GA4 + Meta via server-side GTM


# ─── Telemetry (anonymous usage stats) ──────────────────────
# [optional] PostStack sends a small ANONYMOUS usage report to the maintainer
# once per day (and once on startup). Aggregate counts + deployment shape only —
# no message content, no contact data, no tokens, no raw domain (only salted
# one-way hashes). ON by default (opt-out). Full detail: docs/PRIVACY.md.
# Set to true to turn telemetry off entirely (no report is built, no network call):
# POSTSTACK_TELEMETRY_DISABLED=true
# [optional] Keep telemetry on but POST it to your OWN receiver instead of the
# maintainer's. Default = the official PostStack endpoint.
# TELEMETRY_URL=https://telemetry.techskills.academy/v1/ingest


# ─── License (PRO features) ─────────────────────────────────
# No license = free tier with all free features. A license token (from Sellf)
# unlocks PRO. The defaults below point at the official Sellf seller and accept
# the whole PostStack product family — most operators only set LICENSE_KEY.
#
# [optional] Your purchased license token. The dashboard (Settings → License) can
# also store it; a DB value takes precedence over this env var.
# LICENSE_KEY=
#
# [optional] Seller-scoped JWKS endpoint (the seller is baked into the URL; that
# is what binds tokens to the seller). Default = official PostStack seller.
# LICENSE_JWKS_URL=https://sellf.techskills.academy/api/licenses/jwks?seller=83789f79-bdd7-4918-af1f-e56325fa5070
#
# [optional] Comma-separated allowlist of product slugs the token's `product`
# claim must match. Default accepts the whole PostStack family (annual + lifetime
# + legacy slugs). Override to narrow/extend.
# LICENSE_PRODUCT_SLUG=poststack,poststack-pro,poststack-lifetime,replystack-pro,replystack-pro-lifetime,replystack-business
#
# [optional] Seller-scoped revocation list (CRL): how a refunded/revoked token is
# turned off (verification is offline). Fails OPEN (a fetch outage never locks out
# a paying customer). Default = official seller.
# LICENSE_REVOCATION_URL=https://sellf.techskills.academy/api/licenses/revoked?seller=83789f79-bdd7-4918-af1f-e56325fa5070
#
# [optional] Pinned JWKS snapshot (JSON `{ "keys": [...] }`) — durable fallback
# used only when the live JWKS endpoint is unreachable AND nothing is cached.
# SELLF_JWKS_FALLBACK=
#
# [optional] Where the "requires PRO" UI sends operators to buy a license.
# LICENSE_UPGRADE_URL=https://sellf.techskills.academy/v/poststack-plans
#
# [optional] This instance's public domain for per-domain license binding. A
# token may carry a `domain` claim binding it to one buyer's domain (+subdomains);
# honoured only when this host falls under it. Empty → derived from APP_URL's
# host. Set explicitly when APP_URL is an internal/proxy URL differing from the
# public domain the license was issued for. Unbound tokens ignore this.
# LICENSE_DOMAIN=


# ─── Production images (docker-compose.prod.yml only) ───────
# [optional] Pre-built images are published to GHCR by CI; defaults work out of
# the box. Forks: override IMAGE_REPO with your own registry path (the worker
# image is IMAGE_REPO + "-worker"). If the GHCR packages are private, run
# `docker login ghcr.io` before bringing the stack up.
# IMAGE_REPO=ghcr.io/jurczykpawel/poststack
# IMAGE_TAG=latest
