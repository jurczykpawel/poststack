---
import Logo from "./Logo.astro";
import { footer, site } from "../content/landing";
const year = new Date().getFullYear();
---

<footer class="border-t border-border-subtle py-14">
  <div class="shell grid gap-10 md:grid-cols-[1.4fr_2fr]">
    <div>
      <Logo />
      <p class="mt-4 max-w-[22rem] text-sm text-ink-2">{footer.tagline}</p>
    </div>

    <div class="grid grid-cols-2 gap-8 sm:grid-cols-3">
      {
        footer.columns.map((col) => (
          <nav aria-label={col.heading}>
            <p class="font-[var(--font-mono)] text-xs uppercase tracking-widest text-ink-3">
              {col.heading}
            </p>
            <ul class="mt-4 space-y-2.5">
              {col.links.map((l) => (
                <li>
                  <a
                    href={l.href}
                    rel="noopener"
                    class="text-sm text-ink-2 transition-colors hover:text-ink"
                  >
                    {l.label}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        ))
      }
    </div>
  </div>

  <div class="shell mt-12 border-t border-border-subtle pt-6 text-xs text-ink-3">
    <p class="text-center">
      {footer.ecosystem.label}
      {
        footer.ecosystem.links.map((l) => (
          <>
            {" · "}
            <a
              href={l.href}
              rel="noopener"
              class="text-ink-2 underline-offset-2 transition-colors hover:text-ink hover:underline"
            >
              {l.label}
            </a>
          </>
        ))
      }
    </p>
    <div class="mt-4 flex flex-col items-center justify-between gap-3 sm:flex-row">
      <p>© {year} {site.name}. Source-available · Elastic License 2.0.</p>
      <div class="flex items-center gap-4">
        <a
          href="/privacy"
          class="text-ink-2 transition-colors hover:text-ink"
        >
          Privacy
        </a>
        <a
          href="#cookie-preferences"
          data-cc="show-preferences"
          class="text-ink-2 transition-colors hover:text-ink"
        >
          Cookies
        </a>
      </div>
    </div>
  </div>
</footer>
