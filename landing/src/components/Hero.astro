---
import { hero, proofSignals, site } from "../content/landing";
---

<section id="top" class="relative overflow-hidden pt-32 pb-20 md:pt-40 md:pb-28">
  <!-- atmospheric backdrop (AI render) — faded out before the mockup so it adds depth without competing -->
  <img
    src="/hero-glow.webp"
    alt=""
    aria-hidden="true"
    fetchpriority="high"
    class="pointer-events-none absolute inset-x-0 top-0 h-[820px] w-full object-cover opacity-70 [mask-image:linear-gradient(to_bottom,black_0%,black_38%,transparent_82%)] [-webkit-mask-image:linear-gradient(to_bottom,black_0%,black_38%,transparent_82%)]"
  />

  <!-- ambient glows -->
  <div
    class="glow"
    style="width:680px;height:680px;top:-220px;left:50%;transform:translateX(-50%);background:radial-gradient(circle,#7aa2f7,transparent 65%);opacity:0.32"
  >
  </div>
  <div
    class="glow"
    style="width:420px;height:420px;top:120px;right:-80px;background:radial-gradient(circle,#bb9af7,transparent 65%);opacity:0.28"
  >
  </div>

  <div class="shell relative">
    <div class="mx-auto max-w-[56rem] text-center">
      <a
        href="#pricing"
        data-reveal
        class="mb-7 inline-flex items-center gap-2 rounded-full border border-border-medium bg-floating/70 px-4 py-1.5 text-xs text-ink-2 backdrop-blur transition-colors hover:border-blue/50 hover:text-ink"
      >
        <span class="size-1.5 rounded-full bg-ok shadow-[0_0_8px_var(--color-ok)]"></span>
        {hero.badge}
      </a>

      <h1
        data-reveal
        style="--reveal-delay:60ms"
        class="text-balance text-[clamp(2.6rem,7vw,4.7rem)] font-bold leading-[1.04]"
      >
        {hero.titleLead}
        <span class="grad">{hero.titleAccent}</span>
      </h1>

      <p
        data-reveal
        style="--reveal-delay:140ms"
        class="mx-auto mt-6 max-w-[40rem] text-pretty text-lg text-ink-2"
      >
        {hero.subtitle}
      </p>

      <div
        data-reveal
        style="--reveal-delay:220ms"
        class="mt-9 flex flex-col items-center justify-center gap-3 sm:flex-row"
      >
        <a href="#pricing" class="btn btn-primary w-full sm:w-auto">
          {hero.primaryCta}
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path>
          </svg>
        </a>
        <a href={site.githubUrl} rel="noopener" class="btn btn-ghost w-full sm:w-auto">
          {hero.secondaryCta}
        </a>
      </div>

      <a
        href={hero.assurance.href}
        data-reveal
        style="--reveal-delay:260ms"
        class="group mt-6 inline-flex items-center gap-2 rounded-full border border-ok/40 bg-ok/10 px-4 py-2 text-sm font-medium text-ink transition-colors hover:border-ok/70 hover:bg-ok/15"
      >
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M3.5 8.5l3 3 6-7" stroke="var(--color-ok)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
        <span><span class="text-ok">{hero.assurance.lead}</span> <span class="text-ink-2">{hero.assurance.tail}</span></span>
        <span class="text-ink-3 transition-transform group-hover:translate-x-0.5">→</span>
      </a>
    </div>

    <!-- Faux dashboard mockup -->
    <div
      class="mt-16 [perspective:1600px] md:mt-20"
      data-reveal
      style="--reveal-delay:300ms"
    >
      <div
        data-hero-mock
        class="mx-auto max-w-[58rem] origin-top rounded-2xl border border-border-medium bg-elevated shadow-[0_40px_120px_-40px_rgba(122,162,247,0.35)] [transform-style:preserve-3d]"
      >
        <!-- window chrome -->
        <div class="flex items-center gap-2 border-b border-border-subtle px-4 py-3">
          <span class="size-3 rounded-full bg-bad/70"></span>
          <span class="size-3 rounded-full bg-warn/70"></span>
          <span class="size-3 rounded-full bg-ok/70"></span>
          <span class="ml-3 font-[var(--font-mono)] text-xs text-ink-3">poststack.techskills.academy/inbox</span>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-[150px_1fr]">
          <!-- sidebar -->
          <aside class="hidden flex-col gap-1 border-r border-border-subtle p-3 sm:flex">
            {
              [
                ["Inbox", true],
                ["Rules", false],
                ["Sequences", false],
                ["Contacts", false],
                ["Publish", false],
              ].map(([label, active]) => (
                <span
                  class:list={[
                    "rounded-lg px-3 py-1.5 text-sm",
                    active ? "bg-blue/15 text-ink" : "text-ink-3",
                  ]}
                >
                  {label}
                </span>
              ))
            }
          </aside>

          <!-- thread -->
          <div class="relative space-y-3 p-4 sm:p-5">
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-2">
                <span class="grid size-7 place-items-center rounded-full bg-gradient-to-br from-blue to-purple text-xs font-semibold text-[#0a0a12]">AK</span>
                <div class="leading-tight">
                  <p class="text-sm font-medium text-ink">@anna.k</p>
                  <p class="font-[var(--font-mono)] text-[0.65rem] text-ink-3">Instagram · comment</p>
                </div>
              </div>
              <span class="rounded-full bg-ok/15 px-2 py-0.5 text-[0.65rem] font-medium text-ok">within 24h</span>
            </div>

            <div class="max-w-[80%] rounded-2xl rounded-tl-md bg-floating px-3.5 py-2 text-sm text-ink-2">
              How much is the course? 👀 <span class="font-medium text-blue">PRICE</span>
            </div>

            <!-- the auto-reply, glides in -->
            <div class="ml-auto flex max-w-[82%] flex-col items-end gap-1 [animation:slideUp_0.6s_var(--ease-spring)_0.2s_both]">
              <div class="rounded-2xl rounded-tr-md bg-gradient-to-br from-blue to-purple px-3.5 py-2 text-sm font-medium text-[#0a0a12]">
                Hi! Here's everything about the course + a discount link 👇
              </div>
              <span class="font-[var(--font-mono)] text-[0.6rem] text-ink-3">auto-reply · rule “PRICE”</span>
            </div>

            <!-- rule-fired chip -->
            <div
              class="pointer-events-none absolute -bottom-3 right-3 flex items-center gap-2 rounded-full border border-border-medium bg-base/90 px-3 py-1.5 backdrop-blur [animation:popIn_0.5s_var(--ease-spring)_0.7s_both]"
            >
              <span class="size-1.5 animate-pulse rounded-full bg-ok"></span>
              <span class="text-[0.7rem] text-ink-2">Comment → DM · enrolled in sequence</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- proof signals -->
    <ul
      data-reveal
      style="--reveal-delay:380ms"
      class="mt-14 flex flex-wrap items-center justify-center gap-x-6 gap-y-3"
    >
      {
        proofSignals.map((s) => (
          <li class="flex items-center gap-2 text-sm text-ink-3">
            <svg width="15" height="15" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3.5 8.5l3 3 6-7" stroke="#9ece6a" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
            {s}
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  @keyframes slideUp {
    from { opacity: 0; transform: translateY(14px); }
    to { opacity: 1; transform: none; }
  }
  @keyframes popIn {
    from { opacity: 0; transform: translateY(8px) scale(0.92); }
    to { opacity: 1; transform: none; }
  }
</style>
