---
/**
 * Analytics.astro — privacy-first analytics + consent for the PostStack landing.
 *
 * Runtime-configured, NOT build-time. The Hono app injects
 *   <script>window.__POSTSTACK_ANALYTICS__ = { gtmId?, umamiId?, umamiSrc? }</script>
 * into the served HTML from its environment (see src/server/ui/landing.ts). This component only
 * emits the client logic that reads that global. Consequences:
 *   - The public image ships with NO tracking IDs (self-hosters set their own via env).
 *   - test vs prod differ purely by their compose env — no IDs set on test ⇒ zero trackers, no banner.
 *   - Changing IDs needs no rebuild.
 *
 * GTM flows through server-side GTM (t.poststack.techskills.academy → shared TrackStack):
 * GA4 forward + Meta CAPI. Umami is cookieless. Consent (Consent Mode V2) gates GTM; Umami is exempt.
 */
---

<script>
  interface AnalyticsCfg {
    gtmId?: string;
    umamiId?: string;
    umamiSrc?: string;
  }
  const w = window as Window & {
    __POSTSTACK_ANALYTICS__?: AnalyticsCfg;
    dataLayer?: unknown[];
    gtag?: (...args: unknown[]) => void;
    __poststack_gtm_id?: string;
    requestIdleCallback?: (cb: () => void, opts?: { timeout: number }) => void;
  };
  const cfg: AnalyticsCfg = w.__POSTSTACK_ANALYTICS__ || {};

  // GTM Consent Mode V2 defaults (everything denied until the visitor opts in). Set before GTM loads;
  // the consent manager calls gtm.js only after consent (see lib/cookieconsent-init.ts → loadGtm).
  if (cfg.gtmId) {
    w.dataLayer = w.dataLayer || [];
    const gtag: (...args: unknown[]) => void = function () {
      // eslint-disable-next-line prefer-rest-params -- GTM requires the raw `arguments` object
      w.dataLayer!.push(arguments);
    };
    w.gtag = gtag;
    gtag("consent", "default", {
      ad_storage: "denied",
      ad_user_data: "denied",
      ad_personalization: "denied",
      analytics_storage: "denied",
      functionality_storage: "granted",
      personalization_storage: "denied",
      security_storage: "granted",
      wait_for_update: 500,
    });
    w.dataLayer.push({ source_brand: "poststack" });
    w.__poststack_gtm_id = cfg.gtmId;
  }

  // Umami: cookieless, consent-exempt — load directly when configured.
  if (cfg.umamiId) {
    const s = document.createElement("script");
    s.defer = true;
    s.src = cfg.umamiSrc || "https://stats.techskills.academy/script.js";
    s.setAttribute("data-website-id", cfg.umamiId);
    s.setAttribute("data-domains", location.hostname);
    document.head.appendChild(s);
  }

  // Consent manager governs the GTM cookie categories, so load it only when GTM is configured.
  // It also powers the footer "Cookies" link (data-cc="show-preferences").
  if (cfg.gtmId) {
    let loaded: Promise<typeof import("../lib/cookieconsent-init")> | null = null;
    const loadCC = () => {
      if (!loaded) {
        loaded = import("../lib/cookieconsent-init").then(async (mod) => {
          await mod.initCookieConsent();
          return mod;
        });
      }
      return loaded;
    };
    const hasConsent = () => {
      if (document.cookie.includes("poststack_consent=")) return true;
      try {
        return !!localStorage.getItem("poststack_cc_v1");
      } catch {
        return false;
      }
    };
    const ric = w.requestIdleCallback;
    const scheduleCC = () => {
      if (hasConsent()) {
        loadCC();
      } else if (typeof ric === "function") {
        ric(loadCC, { timeout: 10000 });
      } else {
        window.setTimeout(loadCC, 4000);
      }
    };
    if (document.readyState === "complete") {
      scheduleCC();
    } else {
      window.addEventListener("load", scheduleCC, { once: true });
    }
    document.addEventListener(
      "click",
      (e) => {
        const t =
          e.target instanceof Element
            ? e.target.closest('[data-cc="show-preferences"], a[href="#cookie-preferences"]')
            : null;
        if (t) {
          e.preventDefault();
          loadCC().then((mod) => mod.showCookiePreferences());
        }
      },
      { capture: true },
    );
  }
</script>
