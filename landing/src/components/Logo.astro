---
/**
 * PostStack logo: a stack of post layers whose top layer unfolds into a
 * message bubble (with a tail). Geometric, gradient blue→purple.
 */
interface Props {
  showWordmark?: boolean;
  class?: string;
}
const { showWordmark = true, class: className = "" } = Astro.props;
const gid = "psg-" + Math.random().toString(36).slice(2, 8);
---

<span class={`inline-flex items-center gap-2.5 ${className}`}>
  <svg
    width="30"
    height="30"
    viewBox="0 0 32 32"
    fill="none"
    role="img"
    aria-label="PostStack logo"
    class="shrink-0"
  >
    <defs>
      <linearGradient id={gid} x1="4" y1="5" x2="28" y2="27" gradientUnits="userSpaceOnUse">
        <stop stop-color="#7aa2f7"></stop>
        <stop offset="1" stop-color="#bb9af7"></stop>
      </linearGradient>
    </defs>
    <!-- lower layers of the stack -->
    <rect x="7" y="22.5" width="18" height="4" rx="2" fill="#bb9af7" opacity="0.28"></rect>
    <rect x="5.5" y="16.5" width="21" height="4.5" rx="2.25" fill="#7aa2f7" opacity="0.5"></rect>
    <!-- top layer: a message card with a tail -->
    <path
      d="M6 6.5C6 5.12 7.12 4 8.5 4h15C24.88 4 26 5.12 26 6.5v5C26 12.88 24.88 14 23.5 14H12.7l-3.5 2.8A1 1 0 0 1 7.6 16v-2H8.5C7.12 14 6 12.88 6 11.5v-5Z"
      fill={`url(#${gid})`}></path>
  </svg>
  {
    showWordmark && (
      <span class="font-[var(--font-display)] text-[1.15rem] font-bold tracking-tight text-ink">
        Post<span class="text-ink-2 font-semibold">Stack</span>
      </span>
    )
  }
</span>
