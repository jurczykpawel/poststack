---
/**
 * FollowGate.astro — interactive demo of the PRO follow-gate.
 * A visitor flips the "is this person following you?" toggle, then taps Claim:
 *  - following  → unlocked (the magnet)
 *  - not yet    → locked re-prompt with a "claim again" button (the loop)
 * Pure click interaction (no animation), so it works under reduced-motion. Without JS the DM mock
 * shows the prompt + Claim button statically (the [data-fg] script enhances it).
 */
import { followGate as t } from "../content/landing";
---

<section class="py-[var(--spacing-section)]">
  <div class="shell grid items-center gap-12 lg:grid-cols-[1fr_1fr]">
    <!-- copy + toggle -->
    <div data-reveal>
      <span class="eyebrow">{t.eyebrow}</span>
      <h2 class="mt-4 text-[clamp(1.9rem,4vw,3rem)] font-bold">
        {t.title} <span class="grad">{t.titleAccent}</span>
      </h2>
      <p class="mt-4 text-lg text-ink-2">{t.body}</p>

      <p class="mt-7 font-[var(--font-mono)] text-xs uppercase tracking-widest text-ink-3">{t.toggleLabel}</p>
      <div class="mt-3 inline-flex rounded-full border border-border-medium bg-floating/60 p-1" data-fg-toggle role="tablist">
        <button
          data-fg-follow="0"
          class="fg-seg rounded-full px-4 py-1.5 text-sm font-medium transition-colors"
          role="tab"
        >{t.toggleNotFollowing}</button>
        <button
          data-fg-follow="1"
          class="fg-seg rounded-full px-4 py-1.5 text-sm font-medium transition-colors"
          role="tab"
        >{t.toggleFollowing}</button>
      </div>

      <p class="mt-6 text-xs text-ink-3">{t.note}</p>
    </div>

    <!-- IG DM mock -->
    <div
      data-fg
      data-reveal
      style="--reveal-delay:120ms"
      class="mx-auto w-full max-w-[24rem] rounded-2xl border border-border-medium bg-elevated p-4 shadow-[0_30px_90px_-40px_rgba(122,162,247,0.4)]"
    >
      <div class="flex items-center gap-2 border-b border-border-subtle pb-3">
        <span class="grid size-7 place-items-center rounded-full bg-gradient-to-br from-blue to-purple text-xs font-semibold text-[#0a0a12]">F</span>
        <div class="leading-tight">
          <p class="text-sm font-medium text-ink">@follower</p>
          <p class="font-[var(--font-mono)] text-[0.6rem] text-ink-3">Instagram · DM</p>
        </div>
      </div>

      <div class="min-h-[12.5rem] space-y-3 pt-4">
        <!-- bot prompt + claim -->
        <div class="max-w-[88%] space-y-2.5 rounded-2xl rounded-tl-md bg-floating px-3.5 py-3">
          <p class="text-sm text-ink-2">{t.prompt}</p>
          <button
            data-fg-claim
            class="inline-flex items-center rounded-lg bg-gradient-to-br from-blue to-purple px-3 py-1.5 text-sm font-semibold text-[#0a0a12] transition-transform hover:scale-[1.02]"
          >{t.claimCta}</button>
        </div>

        <!-- outcome (filled by JS on claim) -->
        <div data-fg-outcome class="ml-auto max-w-[88%]" hidden></div>
      </div>
    </div>
  </div>
</section>

<style>
  .fg-seg { color: var(--color-ink-3); }
  .fg-seg[data-active] {
    background: color-mix(in srgb, var(--color-blue) 18%, transparent);
    color: var(--color-ink);
  }
  [data-fg-outcome] .fg-card {
    border-radius: 1rem 1rem 0.375rem 1rem;
    padding: 0.625rem 0.875rem;
  }
</style>

<script>
  import { followGate as t } from "../content/landing";

  const root = document.querySelector<HTMLElement>("[data-fg]");
  const toggle = document.querySelector<HTMLElement>("[data-fg-toggle]");
  if (root && toggle) {
    const segs = [...toggle.querySelectorAll<HTMLButtonElement>("[data-fg-follow]")];
    const claim = root.querySelector<HTMLButtonElement>("[data-fg-claim]");
    const outcome = root.querySelector<HTMLElement>("[data-fg-outcome]");
    let following = false;

    const setFollow = (v: boolean) => {
      following = v;
      segs.forEach((s) => (s.dataset.follow === (v ? "1" : "0") ? s.setAttribute("data-active", "") : s.removeAttribute("data-active")));
    };

    const render = () => {
      if (!outcome) return;
      if (following) {
        outcome.innerHTML = `<div class="fg-card bg-gradient-to-br from-blue to-purple text-[#0a0a12]">
          <p class="text-sm font-semibold">${t.unlockedTitle}</p>
          <p class="text-sm">${t.unlockedBody}</p>
        </div>`;
      } else {
        outcome.innerHTML = `<div class="fg-card border border-border-medium bg-base/70 text-ink-2">
          <p class="text-sm font-semibold text-ink">${t.lockedTitle}</p>
          <p class="mt-0.5 text-sm">${t.lockedBody}</p>
          <button data-fg-reclaim class="mt-2 inline-flex items-center rounded-lg border border-border-medium bg-floating px-2.5 py-1 text-xs font-medium text-ink transition-colors hover:border-blue/50">${t.reclaimCta}</button>
        </div>`;
        outcome.querySelector<HTMLButtonElement>("[data-fg-reclaim]")?.addEventListener("click", render);
      }
      outcome.hidden = false;
    };

    segs.forEach((s) => s.addEventListener("click", () => { setFollow(s.dataset.follow === "1"); if (!outcome?.hidden) render(); }));
    claim?.addEventListener("click", render);
    setFollow(false); // default: not following → shows the loop first
  }
</script>
