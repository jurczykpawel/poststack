---
import { ruleTester } from "../content/landing";
const { eyebrow, title, body, hint, rules } = ruleTester;
const first = rules[0];
---

<section class="py-[var(--spacing-section)]">
  <div class="shell grid items-center gap-12 lg:grid-cols-[1fr_1fr]">
    <!-- copy + triggers -->
    <div data-reveal>
      <span class="eyebrow">{eyebrow}</span>
      <h2 class="mt-4 text-[clamp(1.9rem,4vw,3rem)] font-bold">{title}</h2>
      <p class="mt-4 text-lg text-ink-2">{body}</p>

      <p class="mt-7 font-[var(--font-mono)] text-xs uppercase tracking-widest text-ink-3">{hint}</p>
      <div class="mt-3 flex flex-wrap gap-2.5" data-rt-triggers>
        {
          rules.map((r, i) => (
            <button
              type="button"
              data-rt-trigger={i}
              aria-pressed={i === 0 ? "true" : "false"}
              class="rt-chip rounded-full border px-4 py-2 font-[var(--font-mono)] text-sm font-medium transition-colors"
            >
              {r.keyword}
            </button>
          ))
        }
      </div>
    </div>

    <!-- live DM frame -->
    <div data-reveal style="--reveal-delay:120ms">
      <div
        class="mx-auto w-full max-w-[24rem] rounded-2xl border border-border-medium bg-elevated p-4 shadow-[0_30px_90px_-40px_rgba(122,162,247,0.4)]"
      >
        <div class="flex items-center justify-between border-b border-border-subtle pb-3">
          <div class="flex items-center gap-2">
            <span class="grid size-7 place-items-center rounded-full bg-gradient-to-br from-blue to-purple text-xs font-semibold text-[#0a0a12]">F</span>
            <div class="leading-tight">
              <p class="text-sm font-medium text-ink">@follower</p>
              <p class="font-[var(--font-mono)] text-[0.6rem] text-ink-3">Instagram · DM</p>
            </div>
          </div>
          <span data-rt-match class="rounded-full bg-ok/15 px-2 py-0.5 text-[0.6rem] font-medium text-ok opacity-0 transition-opacity">
            rule matched
          </span>
        </div>

        <div class="min-h-[12.5rem] space-y-3 pt-4">
          <!-- incoming -->
          <div class="max-w-[82%] rounded-2xl rounded-tl-md bg-floating px-3.5 py-2 text-sm text-ink-2">
            <span data-rt-comment>{first.comment}</span>
          </div>

          <!-- typing indicator -->
          <div data-rt-typing class="ml-auto hidden w-fit rounded-2xl rounded-tr-md bg-floating px-3.5 py-3">
            <span class="rt-dots inline-flex gap-1">
              <i></i><i></i><i></i>
            </span>
          </div>

          <!-- reply -->
          <div data-rt-replywrap class="ml-auto flex max-w-[85%] flex-col items-end gap-1.5 opacity-0">
            <div class="rounded-2xl rounded-tr-md bg-gradient-to-br from-blue to-purple px-3.5 py-2 text-sm font-medium text-[#0a0a12]">
              <span data-rt-reply>{first.reply}</span>
            </div>
            <div data-rt-buttons class="flex flex-wrap justify-end gap-2"></div>
            <span class="font-[var(--font-mono)] text-[0.55rem] text-ink-3">auto-reply · within 24h</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .rt-chip {
    color: var(--color-ink-2);
    border-color: var(--color-border-medium);
    background: var(--color-floating);
  }
  .rt-chip:hover {
    color: var(--color-ink);
    border-color: color-mix(in srgb, var(--color-blue) 45%, transparent);
  }
  .rt-chip[aria-pressed="true"] {
    color: #0a0a12;
    border-color: transparent;
    background: linear-gradient(120deg, var(--color-blue), var(--color-purple));
  }

  .rt-dots i {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-ink-3);
    animation: rt-blink 1.2s var(--ease-spring) infinite;
  }
  .rt-dots i:nth-child(2) {
    animation-delay: 0.18s;
  }
  .rt-dots i:nth-child(3) {
    animation-delay: 0.36s;
  }
  @keyframes rt-blink {
    0%, 60%, 100% { opacity: 0.3; transform: translateY(0); }
    30% { opacity: 1; transform: translateY(-2px); }
  }

  .rt-reveal {
    animation: rt-in 0.45s var(--ease-spring) both;
  }
  @keyframes rt-in {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .rt-dots i { animation: none; }
    .rt-reveal { animation: none; }
  }
</style>
