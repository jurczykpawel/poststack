---
import { scrollStory } from "../content/landing";
const { eyebrow, title, scenes } = scrollStory;
---

<section data-scrollstory class="relative py-[var(--spacing-section)]">
  <!-- ambient aura so the long pinned-scroll black space feels alive (parallax added by motion.ts) -->
  <div class="bg-aura" data-inview-play aria-hidden="true">
    <div class="bg-aura-grid"></div>
    <div class="bg-aura-orbs" data-parallax-orbs>
      <span class="bg-orb bg-orb-a"></span>
      <span class="bg-orb bg-orb-b"></span>
      <span class="bg-orb bg-orb-c"></span>
    </div>
  </div>

  <div class="shell">
    <div class="mx-auto max-w-[44rem] text-center" data-reveal>
      <span class="eyebrow justify-center">{eyebrow}</span>
      <h2 class="mt-4 text-[clamp(1.9rem,4vw,3rem)] font-bold">{title}</h2>
    </div>

    <div data-story-stagewrap class="mt-14">
      <div class="grid items-center gap-10 lg:grid-cols-[0.9fr_1.1fr]">
        <!-- captions + progress rail -->
        <ol data-story-caps class="relative flex flex-col gap-7 pl-6">
          <span
            class="absolute left-0 top-1 bottom-1 w-px bg-border-medium"
            aria-hidden="true"></span>
          <span
            data-story-fill
            class="absolute left-0 top-1 w-px origin-top bg-gradient-to-b from-blue to-purple"
            style="height:calc(100% - 0.5rem);transform:scaleY(0)"
            aria-hidden="true"></span>
          {
            scenes.map((s, i) => (
              <li data-story-cap class="relative" data-active={i === 0 ? "" : undefined}>
                <span class="absolute -left-[1.65rem] top-1.5 grid size-3 place-items-center">
                  <span class="story-dot size-2.5 rounded-full border border-border-medium bg-base" />
                </span>
                <p class="font-[var(--font-mono)] text-xs uppercase tracking-widest text-blue">
                  {String(i + 1).padStart(2, "0")} · {s.label}
                </p>
                <h3 class="mt-1.5 text-lg font-semibold text-ink">{s.title}</h3>
                <p class="mt-1.5 text-[0.95rem] text-ink-2">{s.body}</p>
              </li>
            ))
          }
        </ol>

        <!-- stage: three stacked scenes -->
        <div
          data-story-stage
          class="relative mx-auto w-full max-w-[26rem] rounded-2xl border border-border-medium bg-elevated p-4 shadow-[0_30px_90px_-40px_rgba(122,162,247,0.4)]"
        >
          <div class="flex items-center gap-1.5 pb-3">
            <span class="size-2.5 rounded-full bg-bad/70"></span>
            <span class="size-2.5 rounded-full bg-warn/70"></span>
            <span class="size-2.5 rounded-full bg-ok/70"></span>
          </div>

          <div class="story-frame relative">
            <!-- Scene 0 — Capture -->
            <div data-story-scene class="space-y-3">
              <!-- faux post creative (so the frame reads as a real Instagram post, not an empty box) -->
              <div class="relative aspect-[16/9] w-full overflow-hidden rounded-xl bg-gradient-to-br from-blue/35 via-purple/20 to-base">
                <div
                  class="absolute inset-0 opacity-[0.12]"
                  style="background-image:radial-gradient(#fff 1px,transparent 1.4px);background-size:16px 16px"
                  aria-hidden="true"
                >
                </div>
                <span
                  class="absolute right-2.5 top-2.5 rounded-md bg-black/30 px-1.5 py-0.5 font-[var(--font-mono)] text-[0.55rem] text-white/80 backdrop-blur"
                  >NEW</span
                >
                <div class="absolute left-3 top-3 grid size-9 place-items-center rounded-xl bg-white/10 backdrop-blur">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <path d="M12 4 2.5 9 12 14l9.5-5L12 4Z" fill="#fff" opacity="0.92" />
                    <path d="M6.5 11.5V16c0 1.1 2.46 2 5.5 2s5.5-.9 5.5-2v-4.5" stroke="#fff" stroke-width="1.4" opacity="0.7" />
                    <path d="M21.5 9v4.5" stroke="#fff" stroke-width="1.4" stroke-linecap="round" opacity="0.7" />
                  </svg>
                </div>
                <div class="absolute inset-x-3 bottom-2.5">
                  <p class="text-sm font-bold leading-tight text-white">New course is live 🎓</p>
                  <p class="text-[0.62rem] text-white/65">Comment a keyword for the price drop ↓</p>
                </div>
              </div>
              <p class="font-[var(--font-mono)] text-[0.65rem] text-ink-3">@your.brand · post</p>
              <div class="flex items-start gap-2 rounded-xl bg-floating p-3">
                <span class="grid size-7 shrink-0 place-items-center rounded-full bg-gradient-to-br from-blue to-purple text-[0.65rem] font-semibold text-[#0a0a12]">AK</span>
                <p class="text-sm text-ink-2">
                  <span class="font-medium text-ink">anna.k</span>
                  How much is the course?
                  <span class="story-kw rounded bg-blue/20 px-1 font-medium text-blue">PRICE</span> 🙌
                </p>
              </div>
            </div>

            <!-- Scene 1 — Convert -->
            <div data-story-scene class="space-y-3">
              <div class="flex items-center justify-between">
                <p class="font-[var(--font-mono)] text-[0.65rem] text-ink-3">Direct message · @anna.k</p>
                <span class="rounded-full bg-ok/15 px-2 py-0.5 text-[0.6rem] font-medium text-ok">comment → DM</span>
              </div>
              <div class="max-w-[80%] rounded-2xl rounded-tl-md bg-floating px-3.5 py-2 text-sm text-ink-2">PRICE 🙌</div>
              <div class="ml-auto max-w-[85%] rounded-2xl rounded-tr-md bg-gradient-to-br from-blue to-purple px-3.5 py-2 text-sm font-medium text-[#0a0a12]">
                Hi Anna! Here's the course + your discount link 👇
              </div>
              <div class="ml-auto flex max-w-[85%] flex-wrap justify-end gap-2">
                <span class="rounded-lg border border-border-medium bg-base px-2.5 py-1 text-xs text-ink-2">View course</span>
                <span class="rounded-lg border border-border-medium bg-base px-2.5 py-1 text-xs text-ink-2">Get discount</span>
              </div>
            </div>

            <!-- Scene 2 — Nurture -->
            <div data-story-scene class="space-y-3">
              <div class="rounded-xl bg-floating p-3">
                <div class="flex items-center gap-2">
                  <span class="grid size-8 place-items-center rounded-full bg-gradient-to-br from-blue to-purple text-xs font-semibold text-[#0a0a12]">AK</span>
                  <div>
                    <p class="text-sm font-medium text-ink">Anna K.</p>
                    <div class="mt-0.5 flex gap-1">
                      <span class="rounded bg-blue/15 px-1.5 py-0.5 text-[0.6rem] text-blue">lead</span>
                      <span class="rounded bg-purple/15 px-1.5 py-0.5 text-[0.6rem] text-purple">course</span>
                    </div>
                  </div>
                </div>
              </div>
              <ol class="space-y-2">
                {
                  ["Now · welcome + link", "Day 2 · social proof", "Day 5 · last-call offer"].map(
                    (step, i) => (
                      <li class="story-step flex items-center gap-2.5 rounded-lg border border-border-subtle bg-base/50 px-3 py-2" style={`--step:${i}`}>
                        <span class="grid size-5 place-items-center rounded-full bg-blue/15 font-[var(--font-mono)] text-[0.6rem] text-blue">{i + 1}</span>
                        <span class="text-xs text-ink-2">{step}</span>
                      </li>
                    ),
                  )
                }
              </ol>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* Default (no-JS / reduced-motion): scenes stack vertically, all visible. */
  .story-frame > [data-story-scene] + [data-story-scene] {
    margin-top: 1.25rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--color-border-subtle);
  }

  /* Enhanced mode: stage frame holds scenes absolutely; JS crossfades them. */
  [data-scrollstory].is-scrolly .story-frame {
    min-height: 18rem;
  }
  [data-scrollstory].is-scrolly .story-frame > [data-story-scene] {
    position: absolute;
    inset: 0;
    margin: 0;
    padding: 0;
    border: 0;
  }
  [data-scrollstory].is-scrolly .story-frame > [data-story-scene]:not(:first-child) {
    opacity: 0;
  }

  /* Active caption emphasis (enhanced mode). */
  [data-scrollstory].is-scrolly [data-story-cap] {
    opacity: 0.4;
    transition: opacity 0.4s var(--ease-spring);
  }
  [data-scrollstory].is-scrolly [data-story-cap][data-active] {
    opacity: 1;
  }
  [data-scrollstory].is-scrolly [data-story-cap][data-active] .story-dot {
    border-color: var(--color-blue);
    background: var(--color-blue);
    box-shadow: 0 0 10px var(--color-blue);
  }
</style>
