---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Hero from "../components/Hero.astro";
import PlatformBar from "../components/PlatformBar.astro";
import Comparison from "../components/Comparison.astro";
import ScrollStory from "../components/ScrollStory.astro";
import Capabilities from "../components/Capabilities.astro";
import RuleTester from "../components/RuleTester.astro";
import FollowGate from "../components/FollowGate.astro";
import Workflow from "../components/Workflow.astro";
import PublishMorph from "../components/PublishMorph.astro";
import UseCases from "../components/UseCases.astro";
import LeadCapture from "../components/LeadCapture.astro";
import DataFlow from "../components/DataFlow.astro";
import FounderLetter from "../components/FounderLetter.astro";
import FleetStats from "../components/FleetStats.astro";
import TestimonialsSlot from "../components/TestimonialsSlot.astro";
import Roadmap from "../components/Roadmap.astro";
import MetaAccess from "../components/MetaAccess.astro";
import Pricing from "../components/Pricing.astro";
import Faq from "../components/Faq.astro";
import FinalCta from "../components/FinalCta.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout>
  <Nav />
  <main id="main">
    <Hero />
    <PlatformBar />
    <Comparison />
    <ScrollStory />
    <Capabilities />
    <RuleTester />
    <FollowGate />
    <Workflow />
    <PublishMorph />
    <UseCases />
    <LeadCapture />
    <DataFlow />
    <FounderLetter />
    <FleetStats />
    <TestimonialsSlot />
    <Roadmap />
    <MetaAccess />
    <Pricing />
    <Faq />
    <FinalCta />
  </main>
  <Footer />
</BaseLayout>
