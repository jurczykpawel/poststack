{
  "name": "replystack",
  "version": "0.1.0",
  "private": false,
  "license": "AGPL-3.0",
  "description": "Self-hosted, open-source social media inbox automation. Alternative to ManyChat.",
  "homepage": "https://github.com/jurczykpawel/replystack",
  "repository": {
    "type": "git",
    "url": "https://github.com/jurczykpawel/replystack"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "worker": "tsx worker/inbox-worker.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:push": "prisma db push",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "altcha": "^2.3.0",
    "altcha-lib": "^1.4.1",
    "bullmq": "5.71.1",
    "dotenv": "^17.3.1",
    "ioredis": "5.10.1",
    "jose": "6.2.2",
    "next": "^16.2.1",
    "pg": "^8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "@types/pg": "^8.20.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.1",
    "prisma": "^7.6.0",
    "tsx": "4.21.0",
    "typescript": "6.0.2",
    "vitest": "4.1.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
