{
  "name": "replystack",
  "version": "0.1.0",
  "private": false,
  "license": "AGPL-3.0",
  "description": "Self-hosted, open-source social media inbox automation. Alternative to ManyChat.",
  "homepage": "https://github.com/jurczykpawel/replystack",
  "repository": {
    "type": "git",
    "url": "https://github.com/jurczykpawel/replystack"
  },
  "scripts": {
    "dev": "tsx watch src/server/index.ts",
    "start": "tsx src/server/index.ts",
    "build": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "worker": "tsx worker/inbox-worker.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:push": "prisma db push",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.4",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "altcha-lib": "^1.4.1",
    "dotenv": "^17.3.1",
    "graphile-worker": "^0.16.6",
    "hono": "^4.12.23",
    "jose": "6.2.2",
    "pg": "^8.20.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "25.5.0",
    "@types/pg": "^8.20.0",
    "eslint": "^9.39.4",
    "prisma": "^7.5.0",
    "tsx": "4.21.0",
    "typescript": "6.0.2",
    "typescript-eslint": "^8.20.0",
    "vitest": "4.1.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
